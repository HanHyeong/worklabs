{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WorkLaps",
  "version": "0.1.0",
  "identifier": "com.worklaps.desktop",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "WorkLaps",
        "width": 960,
        "height": 800,
        "minWidth": 720,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true,
        "visible": false
      },
      {
        "label": "quick-add",
        "url": "quick-add.html",
        "title": "",
        "width": 380,
        "height": 354,
        "resizable": false,
        "decorations": false,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
